# Client-side Vite variables. These are exposed to the browser bundle.
VITE_ATLAS_ADMIN_ENABLED=false
VITE_MANGAUPDATES_PROXY_URL=/api/mangaupdates
VITE_LOCAL_MANGAUPDATES_PROXY_URL=http://127.0.0.1:8787/api/mangaupdates
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side variables. Keep these in Vercel or local server env only.
ATLAS_SESSION_SECRET=replace-with-a-long-random-session-secret
GITHUB_ATLAS_TRIGGER_TOKEN=replace-with-a-github-token-with-repo-access
GITHUB_OWNER=your-github-org-or-user
GITHUB_REPO=your-repository-name
GITHUB_ATLAS_REF=main
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key
